# ─────────────────────────────────────────────────────────
# Flourish — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# All EXPO_PUBLIC_ variables are bundled into the client.
# They are not secret-server credentials — they identify
# your Firebase project and are safe to ship in the app.
# Firebase security is enforced by Firestore/Storage rules.
# ─────────────────────────────────────────────────────────

# Firebase project credentials
# Find these in Firebase Console → Project Settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key-here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Development: set to "true" to use the Firebase local emulator suite
# Leave unset or "false" for production
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false

# Firebase App Check
# Web: get from Firebase Console → App Check → Apps → Web (reCAPTCHA v3)
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# Native (dev only): get from Firebase Console → App Check → Apps → debug token
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=your-debug-token

# PostHog Analytics (posthog.com — free tier available)
EXPO_PUBLIC_POSTHOG_API_KEY=your-posthog-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Expo Push Notifications
# Find in Expo Dashboard → Project → Project ID
EXPO_PUBLIC_EXPO_PROJECT_ID=your-expo-project-id

# RevenueCat (revenuecat.com — set up after App Store/Play Console products created)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key
