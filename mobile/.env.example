# ───────────────────────────────────────────────────────────────────
# Flourish — Firebase Web App configuration
# ───────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values from the Firebase
# console: Project settings → General → Your apps → Web app → SDK setup.
#
# NOTE ON SECURITY:
#   These EXPO_PUBLIC_* values are *bundled into the client* and are NOT
#   secret. That is expected and safe for a Firebase Web app — the apiKey
#   only identifies the project. All real security is enforced server-side
#   by Firestore/Storage Security Rules and Firebase App Check.
#   Never put service-account keys, admin credentials, or private API
#   secrets in EXPO_PUBLIC_* variables.
# ───────────────────────────────────────────────────────────────────

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=flourish-7b8c8.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=flourish-7b8c8
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=flourish-7b8c8.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App Check — reCAPTCHA v3 site key (web) used for the debug/dev provider.
# In production builds use Play Integrity (Android) / App Attest (iOS).
EXPO_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_KEY=

# Optional: set to "1" to register an App Check debug token during development.
EXPO_PUBLIC_FIREBASE_APPCHECK_DEBUG=
