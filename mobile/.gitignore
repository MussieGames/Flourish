# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files & secrets — NEVER commit real credentials
.env
.env.local
.env*.local

# Firebase native config (contains project identifiers)
google-services.json
GoogleService-Info.plist
.firebase/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
