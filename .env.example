# Expo public Firebase client config.
# These values identify your Firebase project but are not server secrets.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Functions secrets/params are set with:
# firebase functions:secrets:set RECAPTCHA_ENTERPRISE_API_KEY
# firebase functions:secrets:set WAITLIST_RATE_LIMIT_SALT
# firebase functions:config:set is not used for new secrets.
RECAPTCHA_PROJECT_ID=
RECAPTCHA_SITE_KEY=
