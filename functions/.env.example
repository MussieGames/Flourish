# Cloud Functions environment configuration for Flourish.
# Copy to functions/.env (which is git-ignored) and fill in real values.
#
# IMPORTANT: RECAPTCHA_API_KEY is a SECRET. Do not commit it. If the previously
# hard-coded key was ever committed, rotate it in the Google Cloud console.

# Google Cloud API key with access to the reCAPTCHA Enterprise API.
RECAPTCHA_API_KEY=

# Public reCAPTCHA Enterprise site key used by the web client.
RECAPTCHA_SITE_KEY=
