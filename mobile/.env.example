# ─────────────────────────────────────────────────────────────────────────────
# Flourish — environment variables
# Copy this file to `.env` and fill in the values from your Firebase project.
# NEVER commit your real `.env` file. It is git-ignored.
#
# NOTE: Firebase "Web API keys" are project identifiers, not secrets. They are
# safe to ship in a client bundle. Your data is protected by Firebase Auth,
# App Check, and the Firestore/Storage security rules — not by hiding this key.
# ─────────────────────────────────────────────────────────────────────────────

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# App Check (recommended). reCAPTCHA v3 site key is used for the web build.
# Native builds use Play Integrity (Android) / App Attest (iOS) configured in
# the Firebase console; see README "Security" section.
EXPO_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_V3=

# Optional: only for local development against an App Check-enforced backend.
# Generate from the Firebase console and keep it OUT of source control.
EXPO_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Optional EAS project id (for `eas build`).
EAS_PROJECT_ID=
