{
  "expo": {
    "name": "Flourish",
    "slug": "flourish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flourish",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flourish.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Flourish needs access to your photo library to save and upload memories.",
        "NSCameraUsageDescription": "Flourish needs camera access to capture precious moments.",
        "NSMicrophoneUsageDescription": "Flourish needs microphone access to record video memories.",
        "NSFaceIDUsageDescription": "Flourish uses Face ID to keep your memories secure."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FBF7F2"
      },
      "package": "com.flourish.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C17B5C",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FBF7F2"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Flourish to access your camera to capture precious moments."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Flourish to access your photos to save memories."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "flourish-app"
      }
    }
  }
}
