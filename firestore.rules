rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function childPath(childId) {
      return /databases/$(database)/documents/children/$(childId);
    }

    function childExists(childId) {
      return exists(childPath(childId));
    }

    function childData(childId) {
      return get(childPath(childId)).data;
    }

    function isChildOwner(childId) {
      return signedIn() &&
        childExists(childId) &&
        childData(childId).ownerUid == request.auth.uid;
    }

    function isChildMember(childId) {
      return signedIn() &&
        childExists(childId) &&
        (
          childData(childId).ownerUid == request.auth.uid ||
          childData(childId).caregiverUids[request.auth.uid] == true
        );
    }

    function validDisplayName() {
      return request.resource.data.displayName is string &&
        request.resource.data.displayName.size() > 0 &&
        request.resource.data.displayName.size() <= 80;
    }

    function validNullableIsoDate(fieldName) {
      return request.resource.data[fieldName] == null ||
        (
          request.resource.data[fieldName] is string &&
          request.resource.data[fieldName].matches('^\\d{4}-\\d{2}-\\d{2}$')
        );
    }

    function validCreatedTimestamps() {
      return request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function validUpdatedTimestamp() {
      return request.resource.data.updatedAt == request.time;
    }

    function validMemoryKind() {
      return request.resource.data.kind in ['photo', 'video', 'journal'];
    }

    function validMemoryBody(childId) {
      return request.resource.data.childId == childId &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.note is string &&
        request.resource.data.note.size() <= 5000 &&
        request.resource.data.isSharedWithFamily is bool &&
        validMemoryKind();
    }

    function validNullableTimestamp(fieldName) {
      return request.resource.data[fieldName] == null ||
        request.resource.data[fieldName] is timestamp;
    }

    function validMilestoneBody(childId) {
      return request.resource.data.childId == childId &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 120 &&
        validNullableIsoDate('targetDateIso') &&
        validNullableTimestamp('capturedAt');
    }

    match /users/{uid} {
      allow create: if signedIn() &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly([
          'displayName',
          'email',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() <= 120 &&
        (request.resource.data.email == null || request.resource.data.email is string) &&
        validCreatedTimestamps();

      allow read, update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /children/{childId} {
      allow create: if signedIn() &&
        request.resource.data.keys().hasOnly([
          'ownerUid',
          'caregiverUids',
          'displayName',
          'birthDateIso',
          'schemaVersion',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.caregiverUids is map &&
        request.resource.data.caregiverUids.size() == 0 &&
        request.resource.data.schemaVersion == 1 &&
        validDisplayName() &&
        validNullableIsoDate('birthDateIso') &&
        validCreatedTimestamps();

      allow read: if isChildMember(childId);

      allow update: if isChildOwner(childId) &&
        request.resource.data.keys().hasOnly([
          'ownerUid',
          'caregiverUids',
          'displayName',
          'birthDateIso',
          'schemaVersion',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.ownerUid == resource.data.ownerUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.schemaVersion == resource.data.schemaVersion &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'caregiverUids',
          'displayName',
          'birthDateIso',
          'updatedAt'
        ]) &&
        request.resource.data.caregiverUids is map &&
        validDisplayName() &&
        validNullableIsoDate('birthDateIso') &&
        validUpdatedTimestamp();

      allow delete: if isChildOwner(childId);

      match /memories/{memoryId} {
        allow create: if isChildMember(childId) &&
          request.resource.data.keys().hasOnly([
            'ownerUid',
            'childId',
            'title',
            'note',
            'kind',
            'isSharedWithFamily',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.ownerUid == request.auth.uid &&
          validMemoryBody(childId) &&
          validCreatedTimestamps();

        allow read: if isChildMember(childId);

        allow update: if isChildMember(childId) &&
          request.resource.data.keys().hasOnly(resource.data.keys()) &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.childId == resource.data.childId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title',
            'note',
            'isSharedWithFamily',
            'updatedAt'
          ]) &&
          validMemoryBody(childId) &&
          validUpdatedTimestamp();

        allow delete: if isChildOwner(childId) || resource.data.ownerUid == request.auth.uid;
      }

      match /milestones/{milestoneId} {
        allow create: if isChildMember(childId) &&
          request.resource.data.keys().hasOnly([
            'ownerUid',
            'childId',
            'title',
            'targetDateIso',
            'capturedAt',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.ownerUid == request.auth.uid &&
          request.resource.data.childId == childId &&
          validMilestoneBody(childId) &&
          validCreatedTimestamps();

        allow read: if isChildMember(childId);

        allow update: if isChildMember(childId) &&
          request.resource.data.keys().hasOnly(resource.data.keys()) &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.childId == resource.data.childId &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title',
            'targetDateIso',
            'capturedAt',
            'updatedAt'
          ]) &&
          validMilestoneBody(childId) &&
          validUpdatedTimestamp();

        allow delete: if isChildOwner(childId) || resource.data.ownerUid == request.auth.uid;
      }

      match /invitations/{invitationId} {
        allow read, create, update, delete: if isChildOwner(childId);
      }
    }

    // Waitlist writes go through Cloud Functions only so reCAPTCHA/App Check,
    // rate limiting, normalization, and duplicate handling cannot be bypassed.
    match /waitlist/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
